<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }}</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/cytoscape/3.28.1/cytoscape.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/dagre@0.8.5/dist/dagre.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/cytoscape-dagre@2.5.0/cytoscape-dagre.min.js"></script>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif; background: {{ theme.bg }}; color: {{ theme.text }}; overflow: hidden; height: 100vh; }
#app { display: flex; height: 100vh; }
.sidebar { width: 240px; background: {{ theme.sidebar_bg }}; padding: 16px; display: flex; flex-direction: column; gap: 12px; border-right: 1px solid {{ theme.border }}; }
.sidebar h2 { font-size: 16px; margin-bottom: 4px; color: {{ theme.accent }}; }
.sidebar .section { border-top: 1px solid {{ theme.border }}; padding-top: 12px; }
.sidebar .section-title { font-size: 12px; text-transform: uppercase; color: {{ theme.text_secondary }}; margin-bottom: 8px; letter-spacing: 0.5px; }
.sidebar label { display: flex; align-items: center; gap: 8px; font-size: 13px; padding: 4px 0; cursor: pointer; }
.sidebar select, .sidebar button { width: 100%; padding: 8px; border-radius: 6px; border: 1px solid {{ theme.border }}; background: {{ theme.panel_bg }}; color: {{ theme.text }}; font-size: 12px; cursor: pointer; margin-top: 6px; }
.sidebar button.primary { background: {{ theme.accent }}; color: white; border: none; font-weight: bold; }
.sidebar button:hover { opacity: 0.85; }
#graph-container { flex: 1; position: relative; background: {{ theme.bg }}; }
#cy { width: 100%; height: 100%; }
#stats { position: absolute; top: 12px; left: 12px; background: rgba(0,0,0,0.5); color: #ccc; padding: 8px 12px; border-radius: 6px; font-size: 11px; font-family: monospace; pointer-events: none; }
.detail-panel { width: 280px; background: {{ theme.panel_bg }}; padding: 16px; border-left: 1px solid {{ theme.border }}; overflow-y: auto; }
.detail-panel h3 { font-size: 14px; margin-bottom: 8px; color: {{ theme.accent }}; word-break: break-all; }
.detail-panel .prop { font-size: 12px; padding: 4px 0; border-bottom: 1px solid {{ theme.border }}; }
.detail-panel .prop .k { color: {{ theme.text_secondary }}; display: inline-block; width: 80px; }
.legend { font-size: 11px; color: {{ theme.text_secondary }}; }
.legend-item { display: flex; align-items: center; gap: 6px; margin: 3px 0; }
.legend-dot { width: 12px; height: 12px; border-radius: 3px; }
</style>
</head>
<body>
<div id="app">
  <div class="sidebar">
    <h2>🔗 {{ title }}</h2>
    <div class="section">
      <div class="section-title">视图模式</div>
      <select id="viewMode">
        <option value="table" {% if initial_view == 'table' %}selected{% endif %}>表级视图</option>
        <option value="column" {% if initial_view == 'column' %}selected{% endif %}>字段级视图</option>
        <option value="sql" {% if initial_view == 'sql' %}selected{% endif %}>SQL 依赖</option>
      </select>
    </div>
    <div class="section">
      <div class="section-title">布局</div>
      <select id="layoutSel">
        <option value="dagre" selected>Dagre 分层</option>
        <option value="cose">CoSE 力导向</option>
        <option value="circle">环形</option>
        <option value="breadthfirst">广度优先</option>
      </select>
    </div>
    <div class="section">
      <div class="section-title">节点类型</div>
      <label><input type="checkbox" class="nToggle" data-type="sql" checked> SQL</label>
      <label><input type="checkbox" class="nToggle" data-type="table" checked> 表</label>
      <label><input type="checkbox" class="nToggle" data-type="column"> 字段</label>
      <label><input type="checkbox" class="nToggle" data-type="transform"> Transform</label>
    </div>
    <div class="section">
      <button class="primary" id="fitBtn">适配视图</button>
      <button id="exportPng">导出 PNG</button>
    </div>
    <div class="section">
      <div class="section-title">图例</div>
      <div class="legend">
        <div class="legend-item"><div class="legend-dot" style="background:#9c27b0"></div>SQL 节点</div>
        <div class="legend-item"><div class="legend-dot" style="background:#2196f3"></div>表节点</div>
        <div class="legend-item"><div class="legend-dot" style="background:#4caf50"></div>字段节点</div>
        <div class="legend-item"><div class="legend-dot" style="background:#ff9800"></div>Transform</div>
      </div>
    </div>
  </div>
  <div id="graph-container">
    <div id="stats"></div>
    <div id="cy"></div>
  </div>
  <div class="detail-panel" id="detail">
    <h3>点击节点查看详情</h3>
    <p style="font-size:12px;color:{{theme.text_secondary}}">悬停节点可高亮相邻关系</p>
  </div>
</div>
<script>
const graphData = {{ graph_data|safe }};
const nodeColors = {{ node_colors|safe }};
const edgeColors = {{ edge_colors|safe }};
const theme = {{ theme|safe }};

document.addEventListener('DOMContentLoaded', function() {
  cytoscape.use(cytoscapeDagre);
  const cy = cytoscape({
    container: document.getElementById('cy'),
    elements: graphData,
    style: [
      {
        selector: 'node',
        style: {
          'background-color': 'data(bg)',
          'border-color': 'data(border)',
          'border-width': 2,
          'label': 'data(label)',
          'color': '#fff',
          'text-valign': 'center',
          'text-halign': 'center',
          'font-size': '11px',
          'font-weight': 'bold',
          'text-wrap': 'ellipsis',
          'text-max-width': '100px',
          'width': 'mapData(degree, 0, 20, 40, 120)',
          'height': 'mapData(degree, 0, 20, 40, 80)',
          'padding': '8px',
          'shape': 'round-rectangle',
          'transition-property': 'background-color, border-color, border-width, opacity',
          'transition-duration': '200ms',
        }
      },
      {
        selector: 'node[nodeType="sql"]',
        style: { 'shape': 'round-rectangle', 'border-width': 2 }
      },
      {
        selector: 'node[nodeType="table"]',
        style: { 'shape': 'round-rectangle', 'border-width': function(ele){ return ele.data('isTarget') ? 4 : 2; }, 'border-color': function(ele){ return ele.data('isTarget') ? '#ffd700' : ele.data('border'); } }
      },
      {
        selector: 'node.highlighted',
        style: { 'border-width': 4, 'border-color': '#ffd700', 'z-index': 999 }
      },
      {
        selector: 'node.faded',
        style: { 'opacity': 0.2 }
      },
      {
        selector: 'edge',
        style: {
          'width': 2,
          'line-color': 'data(color)',
          'target-arrow-color': 'data(color)',
          'target-arrow-shape': 'triangle',
          'curve-style': 'bezier',
          'arrow-scale': 1.2,
          'transition-property': 'line-color, opacity, width',
          'transition-duration': '200ms',
        }
      },
      {
        selector: 'edge.highlighted',
        style: { 'width': 4, 'z-index': 999 }
      },
      {
        selector: 'edge.faded',
        style: { 'opacity': 0.1 }
      }
    ],
    layout: { name: 'dagre', rankDir: 'LR', nodeSep: 40, rankSep: 80, animate: true }
  });

  function updateStats() {
    document.getElementById('stats').textContent = '节点: ' + cy.nodes().length + ' | 边: ' + cy.edges().length + ' | 布局: Dagre';
  }
  updateStats();

  cy.on('tap', 'node', function(evt){
    const node = evt.target;
    const d = node.data();
    let html = '<h3 style="color:'+d.bg+'">'+d.label+'</h3>';
    html += '<div class="prop"><span class="k">类型:</span>'+d.nodeType+'</div>';
    html += '<div class="prop"><span class="k">ID:</span> '+d.id+'</div>';
    if(d.dialect) html += '<div class="prop"><span class="k">方言:</span> '+d.dialect+'</div>';
    if(d.expressionType) html += '<div class="prop"><span class="k">表达式:</span> '+d.expressionType+'</div>';
    if(d.expression) html += '<div class="prop"><span class="k">公式:</span><br><code style="font-size:11px;word-break:break-all">'+d.expression+'</code></div>';
    if(d.isCte) html += '<div class="prop"><span class="k">CTE:</span> 是</div>';
    const up = cy.nodes().difference(node.outgoers().union(node.incomers())).intersection(node.predecessors());
    html += '<div class="prop"><span class="k">度数:</span> '+node.degree(true)+'</div>';
    document.getElementById('detail').innerHTML = html;
  });

  cy.on('mouseover', 'node', function(evt){
    const node = evt.target;
    cy.elements().addClass('faded');
    node.removeClass('faded').addClass('highlighted');
    node.closedNeighborhood().removeClass('faded').addClass('highlighted');
  });
  cy.on('mouseout', 'node', function(){
    cy.elements().removeClass('faded highlighted');
  });

  function applyLayout(name) {
    const layouts = {
      dagre: { name: 'dagre', rankDir: 'LR', nodeSep: 40, rankSep: 80, animate: true },
      cose: { name: 'cose', animate: true, nodeRepulsion: 8000, idealEdgeLength: 100 },
      circle: { name: 'circle', animate: true },
      breadthfirst: { name: 'breadthfirst', directed: true, padding: 30 }
    };
    cy.layout(layouts[name] || layouts.dagre).run();
  }

  document.getElementById('layoutSel').addEventListener('change', function(e){ applyLayout(e.target.value); });
  document.getElementById('fitBtn').addEventListener('click', function(){ cy.fit(undefined, 30); });
  document.getElementById('exportPng').addEventListener('click', function(){
    const png = cy.png({bg: theme.bg, full: true, scale: 2});
    const a = document.createElement('a');
    a.href = png; a.download = 'lineage.png'; a.click();
  });
  document.querySelectorAll('.nToggle').forEach(function(cb){
    cb.addEventListener('change', function(){
      const type = this.dataset.type;
      const show = this.checked;
      const nodes = cy.nodes('[nodeType="'+type+'"]');
      if(show) nodes.style('display', 'element');
      else nodes.style('display', 'none');
    });
  });
  document.getElementById('viewMode').addEventListener('change', function(e){
    const mode = e.target.value;
    const toggles = document.querySelectorAll('.nToggle');
    toggles.forEach(t => t.checked = false);
    if(mode === 'table'){
      toggles[0].checked = true; toggles[1].checked = true;
      cy.nodes('[nodeType="column"],[nodeType="transform"]').style('display', 'none');
      cy.nodes('[nodeType="sql"],[nodeType="table"]').style('display', 'element');
    } else if(mode === 'column'){
      toggles.forEach(t => t.checked = true);
      cy.nodes().style('display', 'element');
    } else if(mode === 'sql'){
      toggles[0].checked = true;
      cy.nodes('[nodeType!="sql"]').style('display', 'none');
      cy.nodes('[nodeType="sql"]').style('display', 'element');
    }
    setTimeout(() => applyLayout(document.getElementById('layoutSel').value), 100);
  });
  cy.ready(function(){ cy.fit(undefined, 30); });
});
</script>
</body>
</html>
